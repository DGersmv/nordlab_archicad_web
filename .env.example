# === Required: Zoho SMTP (contact form sends here) ===
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USER=admin@nordlab.net
SMTP_PASS=
# Optional. Must be SMTP_USER or a verified alias in Zoho — omit to use SMTP_USER.
# SMTP_FROM=admin@nordlab.net
SMTP_TO=admin@nordlab.net

# === Optional: Telegram (extra notification channel) ===
# If TELEGRAM_BOT_TOKEN and TELEGRAM_CHAT_ID are unset, Telegram is skipped — no error.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Optional: Cloudflare Turnstile (captcha anti-spam) ===
# Without these keys the form still works — honeypot anti-spam only.
# Get keys: https://dash.cloudflare.com → Turnstile → create site → Site Key + Secret Key
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
